---
import { env } from 'cloudflare:workers';
import Base from '../layouts/Base.astro';
import { ensureSchema, overviewStats } from '../lib/db';

const configured = Boolean(env.ANTHROPIC_API_KEY);

let stats = { invoices: 0, withPdf: 0, mailboxes: 0 };
let dbError: string | null = null;
if (env.DB) {
  try {
    await ensureSchema(env.DB);
    stats = await overviewStats(env.DB);
  } catch (err) {
    dbError = (err as Error).message;
  }
}

const examples = [
  'Total spend by issuer cédula, this year',
  'Top 5 vendors by total spend',
  'How much did I spend with Liberty in 2025?',
  'Count of invoices per month in 2025',
  'Total IVA paid, by currency',
];
---

<Base title="Ask AI · Financing Inbox" active="ask">
  <h1>Ask your invoices</h1>
  <p class="sub">Ask in plain language. Claude (Opus) writes a read-only query over your {stats.invoices.toLocaleString()} invoice(s), double-checks it, runs it, and explains the answer — showing the query and rows so you can verify. Ask follow-ups; it remembers the conversation.</p>

  {!configured && (
    <div class="banner err">
      AI isn’t configured yet. Add an <code>ANTHROPIC_API_KEY</code> secret to the <strong>xml</strong> Worker
      (Cloudflare → Settings → Variables and Secrets), then reload.
    </div>
  )}
  {dbError && <div class="banner err">{dbError}</div>}

  <section class="panel">
    <form id="ask-form">
      <div class="field" style="gap:6px;">
        <label for="question">Your question</label>
        <textarea id="question" name="question" rows="2" placeholder="e.g. Total IVA paid to Liberty in 2025, by currency"
          style="font:inherit; padding:9px 11px; border:1px solid var(--line); border-radius:8px; background:#fff; color:var(--ink); resize:vertical; width:100%;"></textarea>
      </div>
      <div style="display:flex; justify-content:space-between; align-items:center; gap:10px; margin-top:10px; flex-wrap:wrap;">
        <div class="chips" id="chips" style="display:flex; flex-wrap:wrap; gap:6px;">
          {examples.map((ex) => (
            <button type="button" class="btn secondary sm chip" data-q={ex}>{ex}</button>
          ))}
        </div>
        <div style="display:flex; gap:6px; align-items:center;">
          <button type="button" id="clear-btn" class="btn secondary sm" style="display:none;">New conversation</button>
          <button class="btn" id="ask-btn" type="submit" disabled={!configured}>Ask</button>
        </div>
      </div>
    </form>
  </section>

  <div id="status" class="muted" style="display:none; margin-bottom:16px;"></div>
  <div id="error" class="banner err" style="display:none;"></div>

  <div id="thread"></div>

  <script is:inline>
    (function () {
      const form = document.getElementById('ask-form');
      const input = document.getElementById('question');
      const btn = document.getElementById('ask-btn');
      const clearBtn = document.getElementById('clear-btn');
      const statusEl = document.getElementById('status');
      const errorEl = document.getElementById('error');
      const thread = document.getElementById('thread');

      // Conversation memory sent back so follow-ups have context.
      let history = [];

      document.getElementById('chips').addEventListener('click', function (e) {
        const b = e.target.closest('.chip');
        if (!b) return;
        input.value = b.getAttribute('data-q');
        input.focus();
      });

      clearBtn.addEventListener('click', function () {
        history = [];
        thread.innerHTML = '';
        clearBtn.style.display = 'none';
        errorEl.style.display = 'none';
        input.focus();
      });

      // ---- tiny, safe Markdown renderer (tables, bold, code, headings, lists) ----
      function inlineInto(el, text) {
        const re = /(\*\*([^*]+)\*\*|`([^`]+)`)/g;
        let last = 0, m;
        while ((m = re.exec(text))) {
          if (m.index > last) el.appendChild(document.createTextNode(text.slice(last, m.index)));
          if (m[2] !== undefined) { const b = document.createElement('strong'); b.textContent = m[2]; el.appendChild(b); }
          else { const c = document.createElement('code'); c.textContent = m[3]; el.appendChild(c); }
          last = m.index + m[0].length;
        }
        if (last < text.length) el.appendChild(document.createTextNode(text.slice(last)));
      }
      function splitRow(line) {
        let s = line.trim();
        if (s.startsWith('|')) s = s.slice(1);
        if (s.endsWith('|')) s = s.slice(0, -1);
        return s.split('|').map(function (c) { return c.trim(); });
      }
      function isSep(line) { return line && /^[\s|:\-]+$/.test(line) && line.indexOf('-') !== -1; }
      function renderMarkdown(md, container) {
        const lines = String(md == null ? '' : md).replace(/\r/g, '').split('\n');
        let i = 0;
        while (i < lines.length) {
          const line = lines[i];
          if (!line.trim()) { i++; continue; }
          // table
          if (line.indexOf('|') !== -1 && i + 1 < lines.length && isSep(lines[i + 1])) {
            const header = splitRow(line);
            i += 2;
            const body = [];
            while (i < lines.length && lines[i].indexOf('|') !== -1 && lines[i].trim()) { body.push(splitRow(lines[i])); i++; }
            const wrap = document.createElement('div'); wrap.className = 'table-wrap'; wrap.style.margin = '8px 0';
            const table = document.createElement('table');
            const thead = document.createElement('thead'); const htr = document.createElement('tr');
            header.forEach(function (h) { const th = document.createElement('th'); inlineInto(th, h); htr.appendChild(th); });
            thead.appendChild(htr); table.appendChild(thead);
            const tbody = document.createElement('tbody');
            body.forEach(function (r) {
              const tr = document.createElement('tr');
              header.forEach(function (_h, idx) { const td = document.createElement('td'); inlineInto(td, r[idx] == null ? '' : r[idx]); tr.appendChild(td); });
              tbody.appendChild(tr);
            });
            table.appendChild(tbody); wrap.appendChild(table); container.appendChild(wrap);
            continue;
          }
          // heading
          const h = line.match(/^(#{1,4})\s+(.*)$/);
          if (h) { const el = document.createElement(h[1].length <= 2 ? 'h3' : 'h4'); inlineInto(el, h[2]); container.appendChild(el); i++; continue; }
          // unordered list
          if (/^\s*[-*]\s+/.test(line)) {
            const ul = document.createElement('ul'); ul.style.margin = '6px 0 6px 18px';
            while (i < lines.length && /^\s*[-*]\s+/.test(lines[i])) { const li = document.createElement('li'); inlineInto(li, lines[i].replace(/^\s*[-*]\s+/, '')); ul.appendChild(li); i++; }
            container.appendChild(ul); continue;
          }
          // paragraph (consecutive plain lines)
          const p = document.createElement('p'); p.style.margin = '6px 0';
          let first = true;
          while (i < lines.length && lines[i].trim() && !/^(#{1,4})\s+/.test(lines[i]) && !/^\s*[-*]\s+/.test(lines[i]) &&
                 !(lines[i].indexOf('|') !== -1 && i + 1 < lines.length && isSep(lines[i + 1]))) {
            if (!first) p.appendChild(document.createElement('br'));
            inlineInto(p, lines[i]); first = false; i++;
          }
          container.appendChild(p);
        }
      }

      function fmtCell(v) {
        if (v === null || v === undefined) return '—';
        if (typeof v === 'number') return Number.isInteger(v) ? v.toLocaleString() : v.toLocaleString(undefined, { maximumFractionDigits: 2 });
        return String(v);
      }
      function rowsTable(rows) {
        const wrap = document.createElement('div'); wrap.className = 'table-wrap';
        const table = document.createElement('table');
        const thead = document.createElement('thead'); const htr = document.createElement('tr');
        const cols = Object.keys(rows[0]);
        cols.forEach(function (c) { const th = document.createElement('th'); th.textContent = c; htr.appendChild(th); });
        thead.appendChild(htr); table.appendChild(thead);
        const tbody = document.createElement('tbody');
        rows.forEach(function (row) {
          const tr = document.createElement('tr');
          cols.forEach(function (c) { const td = document.createElement('td'); const v = row[c]; td.textContent = fmtCell(v); if (typeof v === 'number') td.className = 'num'; tr.appendChild(td); });
          tbody.appendChild(tr);
        });
        table.appendChild(tbody); wrap.appendChild(table);
        return wrap;
      }
      function details(summaryText) {
        const d = document.createElement('details'); d.style.marginTop = '10px';
        const s = document.createElement('summary'); s.className = 'muted'; s.style.cssText = 'cursor:pointer; font-size:13px;'; s.textContent = summaryText;
        d.appendChild(s); return d;
      }

      function addTurn(question, data) {
        const panel = document.createElement('section'); panel.className = 'panel'; panel.style.marginBottom = '16px';
        const q = document.createElement('div');
        q.style.cssText = 'font-weight:600; margin-bottom:8px;';
        q.textContent = 'You: ' + question;
        panel.appendChild(q);
        const ans = document.createElement('div');
        renderMarkdown(data.answer || '(no answer)', ans);
        panel.appendChild(ans);
        if (data.sql) {
          const d = details('Query used (click to verify)');
          const pre = document.createElement('pre');
          pre.style.cssText = 'overflow-x:auto; background:#f3f4f6; padding:10px 12px; border-radius:8px; margin:8px 0 0; font-size:12px; white-space:pre;';
          pre.textContent = data.sql;
          d.appendChild(pre); panel.appendChild(d);
        }
        if (data.rows && data.rows.length) {
          const label = data.truncated ? ('Data (showing ' + data.rows.length + ' of ' + data.rowCount.toLocaleString() + ')') : ('Data (' + data.rowCount.toLocaleString() + ' rows)');
          const d = details(label);
          const box = document.createElement('div'); box.style.marginTop = '8px';
          box.appendChild(rowsTable(data.rows));
          d.appendChild(box); panel.appendChild(d);
        }
        thread.insertBefore(panel, thread.firstChild); // newest on top
        clearBtn.style.display = '';
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        const question = input.value.trim();
        if (!question) return;

        errorEl.style.display = 'none';
        btn.disabled = true;
        const original = btn.textContent;
        btn.textContent = 'Thinking…';
        statusEl.textContent = 'Writing the query, double-checking it, and running it… (a few seconds)';
        statusEl.style.display = '';

        try {
          const res = await fetch('/api/ask', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ question: question, history: history.slice(-6) }),
          });
          const data = await res.json();
          statusEl.style.display = 'none';

          if (!res.ok || data.error) {
            errorEl.textContent = data.error || ('Request failed (' + res.status + ')');
            errorEl.style.display = '';
            if (data.sql) { errorEl.textContent += '  ·  attempted SQL: ' + data.sql; }
          } else {
            addTurn(question, data);
            history.push({ question: question, sql: data.sql || null, answer: data.answer || '' });
            if (history.length > 12) history = history.slice(-12);
            input.value = '';
          }
        } catch (err) {
          statusEl.style.display = 'none';
          errorEl.textContent = 'Network error: ' + (err && err.message ? err.message : err);
          errorEl.style.display = '';
        } finally {
          btn.disabled = false;
          btn.textContent = original;
          input.focus();
        }
      });
    })();
  </script>
</Base>
