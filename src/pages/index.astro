---
import { env } from 'cloudflare:workers';
import Base from '../layouts/Base.astro';
import { ensureSchema, listInvoices, filterOptions, overviewStats, groupByIssuer, getCollectionLock, type InvoiceFilters, type IssuerGroup, type CollectionLock } from '../lib/db';

const url = Astro.url;
const p = url.searchParams;
const collect = p.get('collect');
const view = p.get('view'); // 'issuers' = grouped-by-cédula summary
const ivaParam = p.get('iva');
const ivaRate = ivaParam && Number.isFinite(Number(ivaParam)) ? Number(ivaParam) : undefined;

let dbError: string | null = null;
let data: Awaited<ReturnType<typeof listInvoices>> | null = null;
let options = { accounts: [] as string[], docTypes: [] as string[], monedas: [] as string[], ivaRates: [] as number[], emisores: [] as { id: string; nombre: string; n: number }[] };
let stats = { invoices: 0, withPdf: 0, mailboxes: 0 };
let groups: IssuerGroup[] = [];
let collectionLock: CollectionLock = { active: false, startedAt: null, startedBy: null };

const filters: InvoiceFilters = {
  q: p.get('q') || undefined,
  account: p.get('account') || undefined,
  docType: p.get('docType') || undefined,
  ivaRate,
  emisorId: p.get('emisorId') || undefined,
  receptorId: p.get('receptorId') || undefined,
  from: p.get('from') || undefined,
  to: p.get('to') || undefined,
  hasPdf: p.get('hasPdf') === '1' ? true : p.get('hasPdf') === '0' ? false : undefined,
  sort: p.get('sort') || 'fecha',
  dir: p.get('dir') === 'asc' ? 'asc' : 'desc',
  offset: Number(p.get('offset') || 0),
  limit: 100,
};

if (!env.DB) {
  dbError = 'D1 database binding "DB" not found. Run `npx wrangler d1 create financing-invoices`, paste the id into wrangler.jsonc, then restart.';
} else {
  try {
    await ensureSchema(env.DB);
    [data, options, stats, groups, collectionLock] = await Promise.all([
      listInvoices(env.DB, filters),
      filterOptions(env.DB),
      overviewStats(env.DB),
      view === 'issuers' ? groupByIssuer(env.DB, filters) : Promise.resolve([] as IssuerGroup[]),
      getCollectionLock(env.DB),
    ]);
  } catch (err) {
    dbError = (err as Error).message;
  }
}

// Relative "started N min ago" for the running banner.
function agoText(iso: string | null): string {
  if (!iso) return '';
  const secs = Math.max(0, Math.round((Date.now() - Date.parse(iso)) / 1000));
  if (secs < 60) return 'just now';
  const mins = Math.round(secs / 60);
  if (mins < 60) return `${mins} min ago`;
  const hrs = Math.round(mins / 60);
  return `${hrs} h ago`;
}
const collecting = collectionLock.active;

// --- helpers ---
const money = (n: number | null, moneda: string | null) => {
  if (n == null) return '—';
  try {
    return new Intl.NumberFormat('es-CR', {
      style: 'currency',
      currency: moneda || 'CRC',
      maximumFractionDigits: 2,
    }).format(n);
  } catch {
    return `${(moneda || '')} ${n.toFixed(2)}`.trim();
  }
};
const fmtDate = (iso: string | null) => (iso ? iso.slice(0, 10) : '—');

function qs(overrides: Record<string, string | number | undefined>) {
  const next = new URLSearchParams(url.search);
  for (const [k, v] of Object.entries(overrides)) {
    if (v === undefined || v === '') next.delete(k);
    else next.set(k, String(v));
  }
  return `?${next.toString()}`;
}
function sortLink(key: string, label: string) {
  const isActive = filters.sort === key;
  const nextDir = isActive && filters.dir === 'desc' ? 'asc' : 'desc';
  const arrow = isActive ? (filters.dir === 'desc' ? ' ↓' : ' ↑') : '';
  return { href: qs({ sort: key, dir: nextDir, offset: 0 }), label: label + arrow };
}

const exportHref = `/api/export${qs({ offset: undefined, limit: undefined })}`;
const offset = data?.offset ?? 0;
const limit = data?.limit ?? 100;
const total = data?.total ?? 0;
const showingTo = Math.min(offset + limit, total);
---

<Base title="Dashboard · Recibos XML" active="dashboard">
  <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:12px; flex-wrap:wrap;">
    <div>
      <h1>Invoice dashboard</h1>
      <p class="sub">Electronic invoices (XML) collected from your client mailboxes, with matched PDFs.</p>
    </div>
    <form method="post" action="/api/collect-now" style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
      <label for="lookback" class="muted" style="font-size:12px;">First pull / re-scan</label>
      <select id="lookback" name="lookback" style="min-width:auto;" disabled={collecting}>
        <option value="30">30 days</option>
        <option value="90">3 months</option>
        <option value="180">6 months</option>
        <option value="365">1 year</option>
        <option value="730" selected>2 years</option>
        <option value="1825">5 years</option>
      </select>
      <label class="muted" style="font-size:12px; display:flex; align-items:center; gap:4px;" title="Re-read everything in the window again, even invoices you already have. Use after we change how invoices are extracted. Normally leave off — runs only pull new mail.">
        <input type="checkbox" name="full" value="1" style="min-width:auto; width:auto; padding:0; border:0; background:none;" disabled={collecting} /> re-scan all
      </label>
      <button class="btn" type="submit" disabled={collecting}
        title={collecting ? 'A collection is already running — wait for it to finish' : "Pull invoices from your mailboxes (only new mail unless 're-scan all' is checked)"}
        style={collecting ? 'opacity:.6; cursor:not-allowed;' : ''}>
        {collecting ? '⟳ Collecting…' : '⟳ Collect now'}
      </button>
    </form>
  </div>

  {collecting && <div class="banner warn">⟳ A collection is running (started {agoText(collectionLock.startedAt)}). Only one runs at a time, so <strong>Collect now</strong> is disabled for everyone until it finishes. This page refreshes itself.</div>}
  {collect === 'running' && !collecting && <div class="banner warn">A collection is already running — please wait for it to finish before starting another.</div>}
  {collect === 'queued' && <div class="banner ok">Collection started — it runs in the background, so you can leave this page. Watch progress on the <a href="/mailboxes">Mailboxes</a> page, or the <a href="https://github.com/showyouhow83/XML/actions/workflows/collect.yml" target="_blank" rel="noopener">live log</a>.</div>}
  {collect === 'notoken' && <div class="banner err">“Collect now” needs a GitHub token. Add the <code>GH_DISPATCH_TOKEN</code> secret to the Worker (see README), or run the collector from GitHub Actions.</div>}
  {collect === 'error' && <div class="banner err">Couldn’t start collection — check the <code>GH_DISPATCH_TOKEN</code> secret and that it has Actions read/write on the repo.</div>}
  {dbError && <div class="banner err">{dbError}</div>}

  <section class="cards">
    <div class="card"><span class="card-ic">🧾</span><div class="card-body"><div class="label">Invoices</div><div class="value">{stats.invoices.toLocaleString()}</div></div></div>
    <div class="card"><span class="card-ic">📎</span><div class="card-body"><div class="label">With PDF</div><div class="value">{stats.withPdf.toLocaleString()}</div></div></div>
    <div class="card"><span class="card-ic">📥</span><div class="card-body"><div class="label">Mailboxes</div><div class="value">{stats.mailboxes.toLocaleString()}</div></div></div>
    {(data?.currencyTotals ?? []).map((c) => (
      <div class="card">
        <span class="card-ic">💰</span>
        <div class="card-body">
          <div class="label">Total {c.moneda || '—'} ({c.count})</div>
          <div class="value sm">{money(c.total, c.moneda)}</div>
        </div>
      </div>
    ))}
  </section>

  <form class="panel filters" method="get">
    <div class="field" style="flex:1 1 200px;">
      <label for="q">Search</label>
      <input id="q" type="search" name="q" value={filters.q ?? ''} placeholder="Issuer, ID, clave, consecutivo…" />
    </div>
    <div class="field">
      <label for="account">Mailbox</label>
      <select id="account" name="account">
        <option value="">All</option>
        {options.accounts.map((a) => <option value={a} selected={filters.account === a}>{a}</option>)}
      </select>
    </div>
    <div class="field">
      <label for="docType">Type</label>
      <select id="docType" name="docType">
        <option value="">All</option>
        {options.docTypes.map((t) => <option value={t} selected={filters.docType === t}>{t}</option>)}
      </select>
    </div>
    <div class="field">
      <label for="iva">IVA %</label>
      <select id="iva" name="iva">
        <option value="">All</option>
        {options.ivaRates.map((r) => <option value={r} selected={filters.ivaRate === r}>{r}%</option>)}
      </select>
    </div>
    <div class="field" style="flex:1 1 220px;">
      <label for="emisorId">Issuer (cédula)</label>
      <select id="emisorId" name="emisorId">
        <option value="">All</option>
        {options.emisores.map((e) => (
          <option value={e.id} selected={filters.emisorId === e.id}>{e.nombre} · {e.id} ({e.n})</option>
        ))}
      </select>
    </div>
    <div class="field"><label for="from">From</label><input id="from" type="date" name="from" value={filters.from ?? ''} /></div>
    <div class="field"><label for="to">To</label><input id="to" type="date" name="to" value={filters.to ?? ''} /></div>
    <div class="field">
      <label for="hasPdf">PDF</label>
      <select id="hasPdf" name="hasPdf">
        <option value="">Any</option>
        <option value="1" selected={p.get('hasPdf') === '1'}>Has PDF</option>
        <option value="0" selected={p.get('hasPdf') === '0'}>Missing PDF</option>
      </select>
    </div>
    <input type="hidden" name="sort" value={filters.sort} />
    <input type="hidden" name="dir" value={filters.dir} />
    {view && <input type="hidden" name="view" value={view} />}
    <button class="btn" type="submit">Apply</button>
    <a class="btn secondary" href="/">Reset</a>
    <a class="btn secondary" href={exportHref}>Export CSV</a>
  </form>

  <div style="display:flex; gap:6px; margin-bottom:12px;">
    <a class={`btn sm ${view === 'issuers' ? 'secondary' : ''}`} href={qs({ view: undefined, offset: 0 })}>Invoices</a>
    <a class={`btn sm ${view === 'issuers' ? '' : 'secondary'}`} href={qs({ view: 'issuers', offset: 0 })}>Group by issuer (cédula)</a>
  </div>

  {view === 'issuers' ? (
    groups.length > 0 ? (
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Issuer</th><th>Cédula</th><th class="right"># Invoices</th>
              <th>Cur.</th><th class="right">Total Tax</th><th class="right">Total</th>
            </tr>
          </thead>
          <tbody>
            {groups.map((g) => (
              <tr>
                <td><a href={qs({ emisorId: g.emisor_id, view: undefined, offset: 0 })}>{g.emisor_nombre || '—'}</a></td>
                <td class="muted">{g.emisor_id}</td>
                <td class="num">{g.count}</td>
                <td>{g.moneda}</td>
                <td class="num">{money(g.impuesto, g.moneda)}</td>
                <td class="num"><strong>{money(g.total, g.moneda)}</strong></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      !dbError && <div class="panel empty">No data to group yet.</div>
    )
  ) : data && data.rows.length > 0 ? (
    <>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th><a href={sortLink('fecha', 'Date').href}>{sortLink('fecha', 'Date').label}</a></th>
              <th>Type</th>
              <th><a href={sortLink('emisor', 'Issuer').href}>{sortLink('emisor', 'Issuer').label}</a></th>
              <th>Consecutivo</th>
              <th>Mailbox</th>
              <th>Cur.</th>
              <th class="right">IVA %</th>
              <th class="right"><a href={sortLink('impuesto', 'Tax').href}>{sortLink('impuesto', 'Tax').label}</a></th>
              <th class="right"><a href={sortLink('total', 'Total').href}>{sortLink('total', 'Total').label}</a></th>
              <th>Files</th>
            </tr>
          </thead>
          <tbody>
            {data.rows.map((r) => (
              <tr>
                <td>{fmtDate(r.fecha_emision)}</td>
                <td>{r.doc_type}</td>
                <td title={r.emisor_id}>{r.emisor_nombre || '—'}</td>
                <td class="muted"><a href={`/invoice/${encodeURIComponent(r.clave)}`}>{r.consecutivo}</a></td>
                <td class="muted">{r.source_account}</td>
                <td>{r.moneda}</td>
                <td class="num">{r.iva_rate != null ? `${r.iva_rate}%` : '—'}</td>
                <td class="num">{money(r.total_impuesto, r.moneda)}</td>
                <td class="num"><strong>{money(r.total_comprobante, r.moneda)}</strong></td>
                <td>
                  <div class="rowactions">
                    <a class="btn secondary sm" href={`/api/download?clave=${encodeURIComponent(r.clave)}&type=xml`}>XML</a>
                    {r.has_pdf ? (
                      <a class="btn secondary sm" href={`/api/download?clave=${encodeURIComponent(r.clave)}&type=pdf`}>PDF</a>
                    ) : (
                      <span class="pill muted">no PDF</span>
                    )}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="pager">
        <span>Showing {total === 0 ? 0 : offset + 1}–{showingTo} of {total.toLocaleString()}</span>
        <span>
          {offset > 0 && <a class="btn secondary sm" href={qs({ offset: Math.max(0, offset - limit) })}>← Prev</a>}
          {offset + limit < total && <a class="btn secondary sm" href={qs({ offset: offset + limit })}>Next →</a>}
        </span>
      </div>
    </>
  ) : (
    !dbError && (
      <div class="panel empty">
        No invoices yet. Add client mailboxes on the <a href="/mailboxes">Mailboxes</a> page, then run the collector
        (<code>npm run collect</code> or the scheduled GitHub Action).
      </div>
    )
  )}

  {collecting && <script is:inline>{`setTimeout(function(){ location.reload(); }, 10000);`}</script>}
</Base>
