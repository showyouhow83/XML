---
import { env } from 'cloudflare:workers';
import Base from '../layouts/Base.astro';
import { ensureSchema, listMailboxes, mailboxInvoiceCounts, type MailboxRow } from '../lib/db';

const p = Astro.url.searchParams;

let dbError: string | null = null;
let mailboxes: MailboxRow[] = [];
let counts: Record<string, number> = {};

if (!env.DB) {
  dbError = 'D1 database binding "DB" not found. Create it with `npx wrangler d1 create financing-invoices` and update wrangler.jsonc.';
} else {
  try {
    await ensureSchema(env.DB);
    [mailboxes, counts] = await Promise.all([listMailboxes(env.DB), mailboxInvoiceCounts(env.DB)]);
  } catch (err) {
    dbError = (err as Error).message;
  }
}

const notice = p.get('added') ? 'Mailbox saved.' : p.get('deleted') ? 'Mailbox removed.' : null;
const error = p.get('error');
const fmtDateTime = (iso: string | null) => (iso ? iso.replace('T', ' ').slice(0, 16) : 'never');

function statusInfo(s: string | null) {
  const v = (s || '').toLowerCase();
  if (v.startsWith('collecting')) return { cls: 'warn', text: '⟳ collecting…', title: s || '' };
  if (s === 'ok') return { cls: 'ok', text: '✓ up to date', title: '' };
  if (s) return { cls: 'err', text: 'error', title: s };
  return { cls: 'muted', text: 'pending', title: '' };
}
const anyCollecting = mailboxes.some((m) => (m.last_status || '').toLowerCase().startsWith('collecting'));
---

<Base title="Mailboxes · Recibos XML" active="settings">
  <p class="crumb"><a href="/settings">Settings</a> › Client mailboxes</p>
  <h1>Client mailboxes</h1>
  <p class="sub">IMAP accounts the collector reads invoices from. Passwords are encrypted before they touch the database.</p>

  {dbError && <div class="banner err">{dbError}</div>}
  {notice && <div class="banner ok">{notice}</div>}
  {error && <div class="banner err">{error}</div>}

  <section class="panel">
    <h2>Add / update a mailbox</h2>
    <form method="post" action="/api/mailboxes">
      <div class="grid2">
        <div class="field"><label for="label">Client name</label><input id="label" name="label" placeholder="Acme S.A." /></div>
        <div class="field"><label for="email">Mailbox email *</label><input id="email" name="email" type="email" required placeholder="facturas@acme.cr" /></div>
        <div class="field"><label for="host">IMAP host *</label><input id="host" name="host" required value="imap.gmail.com" /></div>
        <div class="field"><label for="port">Port *</label><input id="port" name="port" type="number" required value="993" /></div>
        <div class="field"><label for="username">Username *</label><input id="username" name="username" required placeholder="usually the email" /></div>
        <div class="field"><label for="password">Password / app password *</label><input id="password" name="password" type="password" required autocomplete="off" /></div>
        <div class="field"><label for="lookbackDays">Look back (days)</label><input id="lookbackDays" name="lookbackDays" type="number" value="30" /></div>
        <div class="field">
          <label for="useSsl">Security</label>
          <select id="useSsl" name="useSsl">
            <option value="1" selected>SSL/TLS (993)</option>
            <option value="0">STARTTLS / plain (143)</option>
          </select>
        </div>
      </div>
      <p style="margin:14px 0 0;"><button class="btn" type="submit">Save mailbox</button></p>
    </form>
    <p class="muted" style="margin-bottom:0;">
      Tip: for Gmail/Workspace accounts use an <strong>app password</strong> (requires 2-step verification), not the login password.
    </p>
  </section>

  <section>
    <h2>Configured mailboxes ({mailboxes.length})</h2>
    {mailboxes.length > 0 ? (
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Client</th><th>Email</th><th class="right">Invoices</th><th>Covers back to</th><th>Last sync</th><th>Status</th><th></th></tr>
          </thead>
          <tbody>
            {mailboxes.map((m) => {
              const si = statusInfo(m.last_status);
              return (
                <tr>
                  <td>{m.label || '—'}</td>
                  <td>{m.email}</td>
                  <td class="num">{(counts[m.email] ?? 0).toLocaleString()}</td>
                  <td class="muted">{m.synced_from ? m.synced_from.slice(0, 10) : '—'}</td>
                  <td class="muted">{fmtDateTime(m.last_synced_at)}</td>
                  <td><span class={`pill ${si.cls}`} title={si.title}>{si.text}</span></td>
                  <td class="right">
                    <span class="row-actions">
                      {(counts[m.email] ?? 0) > 0 && (
                        <a class="btn secondary sm" href={`/api/download-client?account=${encodeURIComponent(m.email)}`} title="Download every PDF for this mailbox as a zip">⬇ PDFs</a>
                      )}
                      <form class="inline" method="post" action="/api/mailboxes/delete" onsubmit="return confirm('Remove this mailbox?')">
                        <input type="hidden" name="id" value={m.id} />
                        <button class="btn danger sm" type="submit">Delete</button>
                      </form>
                    </span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    ) : (
      !dbError && <div class="panel empty">No mailboxes yet. Add one above, or supply a <code>mailboxes.json</code> to the collector.</div>
    )}
  </section>

  <section class="panel" style="margin-top:20px;">
    <h2>How collection runs</h2>
    <p class="muted" style="margin-top:0;">
      A “collector” connects to each mailbox over IMAP, downloads the invoice XML + matching PDF, extracts the data, and stores
      it here. Trigger it with <strong>Collect now</strong> on the dashboard (pick how far back), or it runs nightly. It runs on
      GitHub's servers, so <strong>you can close this page</strong> — it won't stop. Status shows <span class="pill warn">⟳ collecting…</span>
      while a run is in progress and <span class="pill ok">✓ up to date</span> when a mailbox is fully pulled.
      The first pull uses the “how far back” window; after that, runs are <strong>incremental</strong> — they fetch only
      <strong>new mail</strong>, so nothing you already have is downloaded or written again. Invoices are keyed by their Hacienda
      <code>clave</code>, so you can never get duplicates. Tick <strong>“re-scan all”</strong> on the dashboard only when you want
      to re-read everything again (e.g. after we add new extracted fields).
    </p>
  </section>

  {anyCollecting && <script is:inline>{`setTimeout(function(){ location.reload(); }, 8000);`}</script>}
</Base>
