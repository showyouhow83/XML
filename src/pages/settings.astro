---
import { env } from 'cloudflare:workers';
import Base from '../layouts/Base.astro';
import { ensureSchema, listMailboxes, pdfsInD1Count, pdfInvoiceCount, getCollectionSchedule, getAiModel } from '../lib/db';
import { hasLegacyPdfObjects } from '../lib/pdfs';
import { aiModelLabel } from '../lib/ai';
import { describeSchedule, DEFAULT_SCHEDULE, type CollectionSchedule } from '../lib/schedule';

const aiOn = Boolean(env.ANTHROPIC_API_KEY);
const r2On = Boolean(env.PDFS);

let mailboxCount = 0;
let pdfsInD1 = 0;
let pdfCount = 0;
let legacyPdfs = false;
let schedule: CollectionSchedule = DEFAULT_SCHEDULE;
let aiModel: string | null = null;
let dbError: string | null = null;
if (env.DB) {
  try {
    await ensureSchema(env.DB);
    [mailboxCount, pdfsInD1, pdfCount, schedule, legacyPdfs, aiModel] = await Promise.all([
      listMailboxes(env.DB).then((m) => m.length),
      pdfsInD1Count(env.DB),
      pdfInvoiceCount(env.DB),
      getCollectionSchedule(env.DB),
      env.PDFS ? hasLegacyPdfObjects(env.PDFS) : Promise.resolve(false),
      getAiModel(env.DB),
    ]);
  } catch (err) {
    dbError = (err as Error).message;
  }
}
// What Ivan effectively runs: the in-app choice, else the deploy default.
const effectiveAiModel = aiModel || env.AI_MODEL_SQL || 'claude-opus-4-8';
// The organize button should appear only when there's actual work left: PDFs
// still as base64 in D1, or objects still at the old flat R2 keys. Once
// everything is foldered, both are zero and the button goes away (new invoices
// are already stored foldered by ingest, so they never re-trigger it).
const needsOrganize = r2On && (pdfsInD1 > 0 || legacyPdfs);
---

<Base title="Settings · Recibos XML" active="settings">
  <h1>Settings</h1>
  <p class="sub">Everything that controls how invoices are collected, answered, and stored.</p>

  {dbError && <div class="banner err">{dbError}</div>}

  <div class="settings-list">
    <div class="settings-section">
      <h2>Invoice collection</h2>
      <div class="set-group">
        <a class="set-row" href="/mailboxes">
          <span class="set-row-ic">📥</span>
          <span class="set-row-body">
            <span class="t">Client mailboxes</span>
            <span class="d">IMAP accounts invoices are collected from</span>
          </span>
          <span class="set-row-val">
            <span class="v">{mailboxCount} {mailboxCount === 1 ? 'mailbox' : 'mailboxes'}</span>
            <span class="set-row-chev">›</span>
          </span>
        </a>
        <a class="set-row" href="/collection">
          <span class="set-row-ic">⟳</span>
          <span class="set-row-body">
            <span class="t">Collection schedule</span>
            <span class="d">How often invoices are pulled automatically</span>
          </span>
          <span class="set-row-val">
            <span class="v">{describeSchedule(schedule)}</span>
            <span class="set-row-chev">›</span>
          </span>
        </a>
      </div>
    </div>

    <div class="settings-section">
      <h2>Assistant &amp; storage</h2>
      <div class="set-group">
        <a class="set-row" href="/ai">
          <span class="set-row-ic">🤖</span>
          <span class="set-row-body">
            <span class="t">Ivan · Ask AI</span>
            <span class="d">Ask about your invoices in plain Spanish or English</span>
          </span>
          <span class="set-row-val">
            <span class="v">{aiOn ? aiModelLabel(effectiveAiModel) : 'Not configured'}</span>
            <span class="set-row-chev">›</span>
          </span>
        </a>
        <div class="set-row">
          <span class="set-row-ic">🗄️</span>
          <span class="set-row-body">
            <span class="t">PDF storage</span>
            <span class="d" id="pdf-status">
              {!r2On
                ? 'Stored in the database — bind an R2 bucket (PDFS) to move them.'
                : needsOrganize
                  ? pdfsInD1 > 0
                    ? `${pdfsInD1.toLocaleString()} still in the database — organize into R2 by mailbox.`
                    : 'Some PDFs aren’t grouped into mailbox folders yet.'
                  : 'Stored in R2, grouped into a folder per mailbox.'}
            </span>
          </span>
          <span class="set-row-val">
            {needsOrganize
              ? <button id="migrate-pdfs" class="btn secondary sm" type="button" data-total={pdfCount}>Organize</button>
              : <span class="v">{r2On ? 'R2 ✓' : 'Database'}</span>}
          </span>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var btn = document.getElementById('migrate-pdfs');
      var status = document.getElementById('pdf-status');
      if (btn) {
        btn.addEventListener('click', async function () {
          if (btn.getAttribute('data-busy') === '1') return;
          // Instant feedback: spinner + label right away, before the first request.
          if (window.__setBusy) window.__setBusy(btn, true, 'Organizando…'); else btn.disabled = true;
          var offset = 0, moved = 0, done = false;
          try {
            while (true) {
              var res = await fetch('/api/migrate-pdfs', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ offset: offset }) });
              var data = await res.json();
              if (!res.ok || data.error) { status.textContent = data.error || ('Error ' + res.status); break; }
              moved += data.moved || 0;
              offset = data.offset;
              if (data.done) { done = true; status.textContent = 'Listo — PDFs en R2 agrupados por buzón' + (moved ? ' (' + moved + ' movidos)' : '') + '. ✓'; break; }
              status.textContent = 'Organizando… ' + Math.min(offset, data.total) + '/' + data.total + ' (' + moved + ' movidos)';
            }
          } catch (e) { status.textContent = 'Error: ' + (e && e.message ? e.message : e); }
          finally {
            if (window.__setBusy) window.__setBusy(btn, false); else btn.disabled = false;
            if (done) btn.style.display = 'none';
          }
        });
      }
    })();
  </script>
</Base>
