---
import { env } from 'cloudflare:workers';
import Base from '../layouts/Base.astro';
import { ensureSchema, listMailboxes, pdfsInD1Count, pdfInvoiceCount, getCollectionSchedule } from '../lib/db';
import { describeSchedule, DEFAULT_SCHEDULE, type CollectionSchedule } from '../lib/schedule';

let mailboxCount = 0;
let pdfsInD1 = 0;
let pdfCount = 0;
let schedule: CollectionSchedule = DEFAULT_SCHEDULE;
let dbError: string | null = null;
if (env.DB) {
  try {
    await ensureSchema(env.DB);
    [mailboxCount, pdfsInD1, pdfCount, schedule] = await Promise.all([
      listMailboxes(env.DB).then((m) => m.length),
      pdfsInD1Count(env.DB),
      pdfInvoiceCount(env.DB),
      getCollectionSchedule(env.DB),
    ]);
  } catch (err) {
    dbError = (err as Error).message;
  }
}
const aiOn = Boolean(env.ANTHROPIC_API_KEY);
const collectOn = Boolean(env.GH_DISPATCH_TOKEN);
const r2On = Boolean(env.PDFS);
const saved = Astro.url.searchParams.get('saved');

const WEEKDAYS = [
  { v: 1, n: 'Monday' }, { v: 2, n: 'Tuesday' }, { v: 3, n: 'Wednesday' }, { v: 4, n: 'Thursday' },
  { v: 5, n: 'Friday' }, { v: 6, n: 'Saturday' }, { v: 0, n: 'Sunday' },
];
---

<Base title="Settings · Financing Inbox" active="settings">
  <h1>Settings</h1>
  <p class="sub">Manage how the app connects, collects, answers, and stores.</p>

  {dbError && <div class="banner err">{dbError}</div>}
  {saved === 'schedule' && <div class="banner ok">Schedule saved.</div>}

  <div class="settings-grid">
    <a class="setting-card" href="/mailboxes">
      <span class="setting-ic">📥</span>
      <span>
        <strong>Client mailboxes</strong>
        <span class="muted">IMAP accounts the collector reads invoices from · {mailboxCount} configured →</span>
      </span>
    </a>

    <div class="setting-card">
      <span class="setting-ic">🤖</span>
      <span>
        <strong>Ivan · Ask AI</strong>
        <span class="muted">{aiOn ? 'Active — tap 💬 Ivan (bottom-right) on any page to chat.' : 'Not configured — add the ANTHROPIC_API_KEY secret to the Worker.'}</span>
      </span>
    </div>

    <div class="setting-card">
      <span class="setting-ic">⟳</span>
      <span>
        <strong>Collection</strong>
        <span class="muted">{collectOn ? '“Collect now” is enabled (one run at a time).' : 'Add GH_DISPATCH_TOKEN to enable “Collect now”.'} Auto‑runs: <strong>{describeSchedule(schedule)}</strong>.</span>
      </span>
    </div>

    <div class="setting-card">
      <span class="setting-ic">🗄️</span>
      <span>
        <strong>PDF storage</strong>
        <span class="muted" id="pdf-status">
          {r2On
            ? pdfsInD1 > 0
              ? `${pdfsInD1.toLocaleString()} PDF(s) still in the database — move them to R2, grouped by mailbox.`
              : 'PDFs are stored in R2, grouped by mailbox. ✓'
            : 'PDFs are stored in the database. Create an R2 bucket named “xml-pdfs” and bind it as PDFS to move them.'}
        </span>
        {r2On && pdfCount > 0 && (
          <span style="display:block; margin-top:8px;">
            <button id="migrate-pdfs" class="btn secondary sm" type="button" data-total={pdfCount}>Move / organize PDFs by mailbox</button>
          </span>
        )}
      </span>
    </div>
  </div>

  <section class="panel" style="margin-top:20px;">
    <h2>Collection schedule</h2>
    <p class="muted" style="margin-top:0;">
      How often the <strong>automatic</strong> collection runs. <strong>Collect now</strong> always works regardless of this.
      Runs just after midnight Costa Rica time. Current: <strong>{describeSchedule(schedule)}</strong>.
    </p>
    <form method="post" action="/api/schedule" style="display:flex; gap:12px; align-items:flex-end; flex-wrap:wrap;">
      <div class="field">
        <label for="frequency">Frequency</label>
        <select id="frequency" name="frequency">
          <option value="daily" selected={schedule.frequency === 'daily'}>Every night</option>
          <option value="weekly" selected={schedule.frequency === 'weekly'}>Weekly</option>
          <option value="biweekly" selected={schedule.frequency === 'biweekly'}>Every 2 weeks</option>
          <option value="monthly" selected={schedule.frequency === 'monthly'}>Monthly</option>
        </select>
      </div>
      <div class="field" id="dow-field">
        <label for="dayOfWeek">Day of week</label>
        <select id="dayOfWeek" name="dayOfWeek">
          {WEEKDAYS.map((d) => <option value={d.v} selected={(schedule.dayOfWeek ?? 1) === d.v}>{d.n}</option>)}
        </select>
      </div>
      <div class="field" id="dom-field">
        <label for="dayOfMonth">Day of month</label>
        <input id="dayOfMonth" name="dayOfMonth" type="number" min="1" max="31" value={schedule.dayOfMonth ?? 1} />
      </div>
      <button class="btn" type="submit">Save schedule</button>
    </form>
    <p class="muted" style="margin-bottom:0; font-size:12px;">
      For a specific day each month, pick <em>Monthly</em> and set the day (e.g. 5 = the 5th; a day past a short month falls on its last day).
    </p>
  </section>

  <script is:inline>
    (function () {
      var f = document.getElementById('frequency');
      var dow = document.getElementById('dow-field');
      var dom = document.getElementById('dom-field');
      if (f && dow && dom) {
        var sync = function () {
          var v = f.value;
          dow.style.display = v === 'weekly' || v === 'biweekly' ? '' : 'none';
          dom.style.display = v === 'monthly' ? '' : 'none';
        };
        f.addEventListener('change', sync);
        sync();
      }

      var btn = document.getElementById('migrate-pdfs');
      var status = document.getElementById('pdf-status');
      if (btn) {
        btn.addEventListener('click', async function () {
          btn.disabled = true;
          var offset = 0, moved = 0;
          try {
            while (true) {
              var res = await fetch('/api/migrate-pdfs', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ offset: offset }) });
              var data = await res.json();
              if (!res.ok || data.error) { status.textContent = data.error || ('Error ' + res.status); break; }
              moved += data.moved || 0;
              offset = data.offset;
              if (data.done) { status.textContent = 'Listo — PDFs en R2 agrupados por buzón' + (moved ? ' (' + moved + ' movidos)' : '') + '. ✓'; btn.style.display = 'none'; break; }
              status.textContent = 'Organizando… ' + Math.min(offset, data.total) + '/' + data.total + ' (' + moved + ' movidos)';
            }
          } catch (e) { status.textContent = 'Error: ' + (e && e.message ? e.message : e); }
          finally { btn.disabled = false; }
        });
      }
    })();
  </script>
</Base>
